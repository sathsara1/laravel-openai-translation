{
    "name": "sathsara1/laravel-openai-translation",
    "description": "OpenAI-powered translation service for Laravel with support for Chat Completions and Responses API",
    "license": "MIT",
    "authors": [
        {
            "name": "sathsara1",
            "email": "sathsara1@users.noreply.github.com"
        }
    ],
    "keywords": [
        "laravel",
        "openai",
        "translation",
        "gpt",
        "localization"
    ],
    "homepage": "https://github.com/sathsara1/laravel-openai-translation",
    "support": {
        "issues": "https://github.com/sathsara1/laravel-openai-translation/issues",
        "source": "https://github.com/sathsara1/laravel-openai-translation"
    },
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "larastan/larastan": "^2.9",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "suggest": {
        "laravel/framework": "Required for Laravel integration."
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=512M",
        "format": "pint"
    },
    "autoload": {
        "psr-4": {
            "Sathsara1\\LaravelOpenAITranslation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sathsara1\\LaravelOpenAITranslation\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sathsara1\\LaravelOpenAITranslation\\OpenAITranslationServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
